{
  "name": "uTPro.AuditLog",
  "version": "4.0.4",
  "extensions": [
    {
      "type": "menuItem",
      "alias": "uTPro.AuditLog.MenuItem",
      "name": "Audit Log Menu Item",
      "weight": 250,
      "meta": {
        "label": "#utproAuditLog_title",
        "icon": "icon-box-alt",
        "entityType": "utpro-audit-log-root",
        "menus": ["Umb.Menu.AdvancedSettings"]
      }
    },
    {
      "type": "workspace",
      "kind": "default",
      "alias": "uTPro.AuditLog.Workspace",
      "name": "Audit Log Root Workspace",
      "meta": {
        "entityType": "utpro-audit-log-root",
        "headline": "#utproAuditLog_title"
      }
    },
    {
      "type": "workspaceContext",
      "alias": "uTPro.AuditLog.Context",
      "name": "Audit Log Workspace Context",
      "api": "/App_Plugins/utpro-audit-log/context.js",
      "conditions": [
        { "alias": "Umb.Condition.WorkspaceAlias", "match": "uTPro.AuditLog.Workspace" }
      ]
    },
    {
      "type": "workspaceFooterApp",
      "alias": "uTPro.AuditLog.FooterApp",
      "name": "Audit Log Footer App",
      "element": "/App_Plugins/utpro-audit-log/footer.js",
      "conditions": [
        { "alias": "Umb.Condition.WorkspaceAlias", "match": "uTPro.AuditLog.Workspace" }
      ]
    },
    {
      "type": "workspaceView",
      "alias": "uTPro.AuditLog.View.Timeline",
      "name": "Audit Log Timeline View",
      "element": "/App_Plugins/utpro-audit-log/view-timeline.js",
      "weight": 300,
      "meta": {
        "label": "#utproAuditLog_timeline",
        "pathname": "timeline",
        "icon": "icon-time"
      },
      "conditions": [
        { "alias": "Umb.Condition.WorkspaceAlias", "match": "uTPro.AuditLog.Workspace" }
      ]
    },
    {
      "type": "workspaceView",
      "alias": "uTPro.AuditLog.View.ContentLogs",
      "name": "Audit Log Content Logs View",
      "element": "/App_Plugins/utpro-audit-log/view-content.js",
      "weight": 200,
      "meta": {
        "label": "#utproAuditLog_contentLogs",
        "pathname": "content-logs",
        "icon": "icon-document"
      },
      "conditions": [
        { "alias": "Umb.Condition.WorkspaceAlias", "match": "uTPro.AuditLog.Workspace" }
      ]
    },
    {
      "type": "workspaceView",
      "alias": "uTPro.AuditLog.View.AuditTrail",
      "name": "Audit Log Audit Trail View",
      "element": "/App_Plugins/utpro-audit-log/view-audit.js",
      "weight": 100,
      "meta": {
        "label": "#utproAuditLog_auditTrail",
        "pathname": "audit-trail",
        "icon": "icon-notepad"
      },
      "conditions": [
        { "alias": "Umb.Condition.WorkspaceAlias", "match": "uTPro.AuditLog.Workspace" }
      ]
    },
    {
      "type": "localization",
      "alias": "uTPro.AuditLog.Localize.EnUS",
      "name": "Audit Log English",
      "js": "/App_Plugins/utpro-audit-log/lang/en-us.js",
      "meta": { "culture": "en-US" }
    }
  ]
}
