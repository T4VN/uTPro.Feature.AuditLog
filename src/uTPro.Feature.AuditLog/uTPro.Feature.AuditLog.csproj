<Project Sdk="Microsoft.NET.Sdk.Razor">

  <PropertyGroup>
    <!-- net9.0 -> Umbraco 16, net10.0 -> Umbraco 17 & 18 -->
    <TargetFrameworks>net9.0;net10.0</TargetFrameworks>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>

    <!-- NuGet Package Metadata -->
    <PackageId>uTPro.Feature.AuditLog</PackageId>
    <Title>uTPro Audit Log Viewer for Umbraco (16, 17, 18)</Title>
    <Version>4.0.3</Version>
    <Authors>T4VN</Authors>
    <Company>T4VN</Company>
    <Description>Audit log &amp; content log viewer for the Umbraco backoffice (Umbraco 16, 17, 18). Browse, search, filter, sort and export the umbracoAudit and umbracoLog tables from Settings - no SQL needed. Features a unified Timeline, Content Logs and Audit Trail, full-text search, user/date filters, quick date ranges, sortable columns, quick edit links, GMT/UTC toggle, CSV export and shareable URL filters. Read-only, works on SQL Server, SQLite and PostgreSQL. Great for content auditing, user activity tracking, security review and compliance/GDPR reporting.</Description>
    <PackageTags>umbraco;umbraco-marketplace;umbraco-package;audit;audit-log;audit-trail;log;log-viewer;content-log;umbracolog;umbracoaudit;backoffice;activity;tracking;history;security;compliance;gdpr;csv;export;timeline</PackageTags>
    <PackageLicenseExpression>MIT</PackageLicenseExpression>
    <PackageProjectUrl>https://github.com/T4VN/uTPro.Feature.AuditLog</PackageProjectUrl>
    <RepositoryUrl>https://github.com/T4VN/uTPro.Feature.AuditLog</RepositoryUrl>
    <PackageReadmeFile>README.md</PackageReadmeFile>
    <PackageIcon>icon.png</PackageIcon>
    <PackageReleaseNotes>v4.0.3: Dictionary item log entries now resolve to the dictionary key and link straight to the item's editor in the backoffice (Translation section), instead of showing only the numeric node id. Applies to the Timeline and Content Logs views. v4.0.2: Maintenance release — clean rebuild from a wiped output to guarantee the shipped assembly is current (packaging now goes through a deterministic clean-pack step). No source, API, UI or database changes versus 4.0.1. v4.0.1: Republish of the PostgreSQL-compatibility release under a new version number (the 4.0.0 artifact on the feed/cache predated the identifier-quoting fix). PostgreSQL support. All queries now quote table/column identifiers via Umbraco's SqlSyntax provider (GetQuotedTableName/GetQuotedColumnName), so they run correctly on case-sensitive PostgreSQL (e.g. with the Our.Umbraco.PostgreSql provider) in addition to SQL Server and SQLite. Removed hard-coded SQL Server square-bracket identifiers ([Text], [User]) and fixed a column-casing issue (umbracoLog.Datestamp). No functional/UI changes and no database schema changes - purely a database-compatibility release.</PackageReleaseNotes>

    <StaticWebAssetBasePath>App_Plugins/utpro-audit-log</StaticWebAssetBasePath>
    <!-- Packages are produced only via the repo's pack.ps1 (clean build + cache eviction),
         never automatically on every build — this prevents shipping a stale/Debug assembly. -->
    <PackageOutputPath>..\..\Build</PackageOutputPath>
  </PropertyGroup>

  <!-- Umbraco 16 (runs on .NET 9) -->
  <ItemGroup Condition="'$(TargetFramework)' == 'net9.0'">
    <PackageReference Include="Umbraco.Cms.Api.Management" Version="[16.0.0, 17.0.0)" />
  </ItemGroup>

  <!-- Umbraco 17 and 18 (run on .NET 10) -->
  <ItemGroup Condition="'$(TargetFramework)' == 'net10.0'">
    <PackageReference Include="Umbraco.Cms.Api.Management" Version="[17.0.0, 19.0.0)" />
  </ItemGroup>

  <ItemGroup>
    <None Include="..\..\README.md" Pack="true" PackagePath="/" />
    <None Include="..\..\icon.png" Pack="true" PackagePath="/" />
    <None Include="..\..\umbraco-marketplace.json" Pack="true" PackagePath="/" />
  </ItemGroup>

</Project>
